# iter-03: fp32 BGE source onnx (1.1 GB) and the optimum staging export dir
# are produced by ops/scripts/export_bge_onnx.py - never publish.
models/bge-reranker-base.onnx
models/bge_export/
# 2026-05-03: int8 BGE migrated from Git LFS to private HF Hub repo
# (Zettelkasten/bge-reranker). Pulled at docker build time. Local copy
# stays on disk for dev runs but is no longer tracked.
models/bge-reranker-base-int8.onnx

# rag_eval transient outputs — regenerated on every eval run; pollute git
# status and don't represent source-of-truth. Specs (PLAN.md, RESEARCH.md,
# baseline.json, queries.json, scores.md, README.md) remain tracked.
docs/rag_eval/common/**/screenshots/
docs/rag_eval/common/**/_runs/
docs/rag_eval/common/**/verification_results.json
docs/rag_eval/common/**/timing_report.md
docs/rag_eval/common/**/eval.json

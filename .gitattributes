# Force LF line endings for shell scripts (prevent CRLF on Windows)
*.sh text eol=lf

# Calibration sets are stored via Git LFS. ONNX models are NOT in LFS —
# bge-reranker-base-int8.onnx now lives in a private HF Hub repo and is
# pulled at docker build time (see ops/Dockerfile). The fp32 source onnx
# has always been gitignored (regenerated by ops/scripts/export_bge_onnx.py).
models/*.parquet filter=lfs diff=lfs merge=lfs -text

# Zettelkasten Capture Bot — environment variable template
# Copy this file to .env and fill in the required values.
#   cp .env.example .env
#
# Secrets must NEVER be committed to version control.
# Non-secret defaults can also be set in ops/config.yaml.

# ── Required ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-from-botfather
ALLOWED_CHAT_ID=your-numeric-telegram-chat-id

# ── Google Gemini (required for AI summarisation) ──────────────────────────────
# Preferred: comma-separated multi-key pool (enables key rotation + model fallback).
# Loaded by website/features/api_key_switching/init_key_pool() as Source 2.
# GEMINI_API_KEYS=key1,key2,key3
#
# Legacy single-key form (Source 3 fallback, still supported for backward compat):
GEMINI_API_KEY=your-gemini-api-key

# ── Reddit API (required for OAuth-backed Reddit extraction) ──────────────────
# The website Reddit ingestor falls back to the public JSON endpoint + HTML
# scraping when these are unset, so captures still work — but the RAG chunk
# backfill (`ops/scripts/backfill_chunks.py --refetch-source`) produces
# noticeably richer content when real OAuth credentials are present.
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=ZettelkastenBot/1.0   # optional; default shown

# ── Webhook (optional — leave unset for polling / development mode) ────────────
# WEBHOOK_MODE=true
# WEBHOOK_URL=https://your-domain.com/your-bot-token
# WEBHOOK_PORT=8443
# WEBHOOK_SECRET=random-secret-string

# ── Storage (optional — defaults shown) ───────────────────────────────────────
# KG_DIRECTORY=./kg_output
# DATA_DIR=./data

# ── AI Model (optional — default shown) ───────────────────────────────────────
# MODEL_NAME=gemini-2.5-flash

# ── Logging (optional — default shown) ────────────────────────────────────────
# LOG_LEVEL=INFO

# ── GitHub Note Storage (optional — for cloud deployment) ────────────────────
# Push Obsidian notes to a GitHub repo instead of writing to local filesystem.
# GITHUB_TOKEN=ghp_your-github-personal-access-token
# GITHUB_REPO=your-username/obsidian-kg
# GITHUB_BRANCH=main

# ── Supabase (optional — for multi-user knowledge graph) ────────────────────
# Hosts the knowledge graph data in Supabase PostgreSQL instead of graph.json.
# Get these from your Supabase project: Settings → API.
# SUPABASE_URL=https://your-project-id.supabase.co
# SUPABASE_ANON_KEY=your-supabase-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── Supabase Auth (optional — for user authentication) ──────────────────────
# JWT secret for validating Supabase Auth tokens server-side.
# Get this from Supabase Dashboard → Settings → API → JWT Secret.
# SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ── Slack Alerts (optional — Gemini API failure notifications) ──────────────
# Incoming Webhook URL for your Slack channel.
# Create one at: https://api.slack.com/messaging/webhooks
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...

# RAG pipeline feature flag
# Set to "false" to disable chunk ingest without a redeploy (pod restart picks it up in <30s).
# Default: true (production).
RAG_CHUNKS_ENABLED=true

# ── RAG admission control (Phase 1B.2 backpressure) ──────────────────────────
# Bounded queue + rerank semaphore per gunicorn worker. Cluster cap = value × workers.
# Lower QUEUE_MAX shifts burst overload from Cloudflare 524 (origin slow) to
# clean HTTP 503 + Retry-After (frontend retry-with-backoff path). With
# concurrency=2 and synth p50≈10s, QUEUE_MAX=3 keeps tail wait under ~15s.
# Iter-05 burst-pressure test: QUEUE_MAX=8 admitted all 12 burst → 11×524.
# Iter-06: QUEUE_MAX=3 should produce ≥6×503 across the 12-burst probe.
RAG_RERANK_CONCURRENCY=2
RAG_QUEUE_MAX=3

# ── Database direct connection (REQUIRED for ops/scripts/apply_migrations.py) ──
# The migration runner connects via psycopg directly to Postgres. The
# auto-assembled DSN (from SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY) targets
# db.<ref>.supabase.co:5432 which is IPv6-only on Supabase as of 2024 and
# does NOT resolve from many networks (incl. some DigitalOcean droplet
# configs). Set this explicitly with the IPv4 pooler endpoint from
# Supabase Studio > Project Settings > Database > Connection string:
#
# SUPABASE_DB_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
#
# Without this, the migration runner aborts the deploy with a clear error.

# ── Razorpay (payments — orders, subscriptions, webhooks) ────────────────────
# Test keys live under https://dashboard.razorpay.com/app/keys (Test Mode toggle).
# Live keys require KYC + activation. KEY_ID is safe to expose to the browser,
# KEY_SECRET and WEBHOOK_SECRET are server-only.
#   RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
#   RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Webhook secret is what you type when registering
# https://<domain>/api/payments/webhook in the Razorpay dashboard.
#   RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# TEST MODE QUIRKS (current as of May 2026):
#   * Razorpay's onboarding wizard still shows the legacy `4111 1111 1111 1111`
#     test card, but that BIN is silently rejected in their current test mode.
#     The correct current test cards are:
#       Visa       4100 2800 0000 1007
#       Mastercard 5500 6700 0000 1002
#       RuPay      6527 6589 0000 1005
#       Amex       3402 5600 0401 007
#     CVV: any random digits. Expiry: any future date. OTP on mock page:
#     4-10 digits = success, 1-3 digits = failure.
#     Source: razorpay.com/docs/payments/payments/test-card-details/
#   * UPI Collect (VPA textbox) deprecated 28 Feb 2026 by NPCI for one-time
#     payments. UPI Autopay (subscriptions) still uses collect for mandate
#     auth — exempt from the deprecation.
#     Source: /docs/announcements/upi-collect-migration/standard-integration/
#   * UPI QR codes are non-scannable placeholders in test mode by design.
#     Real scannable QR generation happens in live mode only (post-KYC).
#     Source: razorpay.com/docs/payments/qr-codes/faqs/
#   * Test UPI IDs `success@razorpay` / `failure@razorpay` only usable where
#     collect is enabled — i.e. mobile UPI Intent + subscription mandates.

# ── Supabase Management API (script-only — psql / migrations) ──
# Used by ops/scripts/apply_iter08_migrations.py and ops/scripts/migrate_graph_to_supabase.py.
# Loaded from root .env (consolidated from former supabase/.env).
SUPABASE_ACCESS_TOKEN=your_supabase_access_token_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── iter-07/08 RAG knobs (env-only, default values listed; see iter-08 RESEARCH.md for rationale) ──
# Phase 1: thematic multiquery variant count (n=3 = iter-08 default; n=5 was iter-07 quota-burn)
RAG_THEMATIC_MULTIQUERY_N=3

# Phase 2.4: snap long-form chunks to nearest sentence end within slack
RAG_CHUNKER_SENTENCE_SNAP_ENABLED=true

# Phase 4.2: chunk-share normalization (1/sqrt(chunk_count) damping); replaces dead kasten_freq
RAG_CHUNK_SHARE_NORMALIZATION_ENABLED=true

# Phase 5: cite-hygiene filter inside _build_citations. DARK CANARY default OFF.
# Flip to true via env-only on droplet AFTER iter-08 baseline run; see RESEARCH.md §5.
RAG_CITE_HYGIENE_ENABLED=false
RAG_CITE_HYGIENE_MIN_KEEP=1
RAG_CITE_HYGIENE_FALLBACK_TOPK=3

# Phase 6: KG entity-anchor boost (1-hop neighbours of resolved entities get +0.05 rrf)
RAG_ANCHOR_BOOST_ENABLED=true
RAG_ANCHOR_BOOST_AMOUNT=0.05

# iter-07 fixes (already merged on master, knobs preserved for canary)
RAG_COMPARE_AWARE_ANTIMAGNET_ENABLED=true
RAG_SUPPRESS_CITATIONS_ON_REFUSAL=true

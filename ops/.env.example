# Zettelkasten Capture Bot — environment variable template
# Copy this file to .env and fill in the required values.
#   cp .env.example .env
#
# Secrets must NEVER be committed to version control.
# Non-secret defaults can also be set in ops/config.yaml.

# ── Required ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-from-botfather
ALLOWED_CHAT_ID=your-numeric-telegram-chat-id

# ── Google Gemini (required for AI summarisation) ──────────────────────────────
# Preferred: comma-separated multi-key pool (enables key rotation + model fallback).
# Loaded by website/features/api_key_switching/init_key_pool() as Source 2.
# GEMINI_API_KEYS=key1,key2,key3
#
# Legacy single-key form (Source 3 fallback, still supported for backward compat):
GEMINI_API_KEY=your-gemini-api-key

# ── Reddit API (required only for /reddit and auto-detected Reddit URLs) ──────
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=ZettelkastenBot/1.0   # optional; default shown

# ── Webhook (optional — leave unset for polling / development mode) ────────────
# WEBHOOK_MODE=true
# WEBHOOK_URL=https://your-domain.com/your-bot-token
# WEBHOOK_PORT=8443
# WEBHOOK_SECRET=random-secret-string

# ── Storage (optional — defaults shown) ───────────────────────────────────────
# KG_DIRECTORY=./kg_output
# DATA_DIR=./data

# ── AI Model (optional — default shown) ───────────────────────────────────────
# MODEL_NAME=gemini-2.5-flash

# ── Logging (optional — default shown) ────────────────────────────────────────
# LOG_LEVEL=INFO

# ── GitHub Note Storage (optional — for cloud deployment) ────────────────────
# Push Obsidian notes to a GitHub repo instead of writing to local filesystem.
# GITHUB_TOKEN=ghp_your-github-personal-access-token
# GITHUB_REPO=your-username/obsidian-kg
# GITHUB_BRANCH=main

# ── Supabase (optional — for multi-user knowledge graph) ────────────────────
# Hosts the knowledge graph data in Supabase PostgreSQL instead of graph.json.
# Get these from your Supabase project: Settings → API.
# SUPABASE_URL=https://your-project-id.supabase.co
# SUPABASE_ANON_KEY=your-supabase-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── Supabase Auth (optional — for user authentication) ──────────────────────
# JWT secret for validating Supabase Auth tokens server-side.
# Get this from Supabase Dashboard → Settings → API → JWT Secret.
# SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ── Slack Alerts (optional — Gemini API failure notifications) ──────────────
# Incoming Webhook URL for your Slack channel.
# Create one at: https://api.slack.com/messaging/webhooks
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
